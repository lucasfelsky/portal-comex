rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function hasCorporateEmail() {
      return isAuthenticated()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@sqquimica\\.com$');
    }

    function hasActiveStatus(status) {
      return status is string
        && status.matches('^[\\s]*[Aa][Tt][Ii][Vv][Oo][\\s]*$');
    }

    function myProfileExists() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myProfile() {
      return myProfileExists()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function myRole() {
      return myProfileExists() ? myProfile().role : null;
    }

    function myStatus() {
      return myProfileExists() ? myProfile().status : null;
    }

    function myName() {
      return myProfileExists() ? myProfile().name : null;
    }

    function isApprovedUser() {
      return hasCorporateEmail() && hasActiveStatus(myStatus());
    }

    function isAdmin() {
      return isApprovedUser() && myRole() == 'admin';
    }

    function isLogistics() {
      return isApprovedUser() && myRole() == 'logistica';
    }

    function isPostCollectionStatus(status) {
      return status in [
        'Carga em Conferência/Etiquetagem',
        'Carga em processo de Entrada',
        'Carga disponível em estoque',
      ];
    }

    function isScheduledCollectionStatus(status) {
      return status in [
        'Coleta Agendada',
        'Veículo no CD para descarga',
        'Carga em Conferência/Etiquetagem',
        'Carga em processo de Entrada',
        'Carga disponível em estoque',
        'Carga recebida',
      ];
    }

    function hasScheduledCollection() {
      return resource.data.collectionScheduledAt is string
        && resource.data.collectionScheduledAt.size() > 0
        && isScheduledCollectionStatus(resource.data.collectionStatus);
    }

    function isLogisticsPostReceiptUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'postReceiptNotes',
        'postReceiptImages',
        'updatedAt',
        'updatedById',
        'updatedByName',
      ]);
    }

    function isLogisticsCollectionStatusUpdate() {
      return hasScheduledCollection()
        && isPostCollectionStatus(request.resource.data.collectionStatus)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'collectionStatus',
          'updatedAt',
          'updatedById',
          'updatedByName',
        ]);
    }

    function isSelfRegistration() {
      return request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'user'
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'Pendente'
        && request.resource.data.statusTone == 'warn';
    }

    function isAllowedSelfUserUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.statusTone == resource.data.statusTone
        && request.resource.data.email == resource.data.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'area',
          'lastAccess',
          'favoriteProcessIds',
          'notes',
          'updatedAt',
        ]);
    }

    match /announcements/{docId} {
      allow read: if isApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /news/{docId} {
      allow read: if isApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /externalNews/{docId} {
      allow read: if isApprovedUser();
      allow write: if false;
    }

    match /barra/{docId} {
      allow read: if isApprovedUser();
      allow create, update, delete: if isAdmin();
    }

    match /processes/{processId} {
      allow read: if isApprovedUser();
      allow create: if isAdmin()
        && request.resource.data.updatedById == request.auth.uid
        && request.resource.data.updatedByName == myName();
      allow delete: if isAdmin();
      allow update: if (
          isAdmin()
          && request.resource.data.updatedById == request.auth.uid
          && request.resource.data.updatedByName == myName()
        ) || (
          isLogistics()
          && request.resource.data.updatedById == request.auth.uid
          && request.resource.data.updatedByName == myName()
          && (isLogisticsPostReceiptUpdate() || isLogisticsCollectionStatusUpdate())
        );

      match /messages/{messageId} {
        allow read: if isApprovedUser();
        allow create: if isApprovedUser()
          && request.resource.data.processId == processId
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.authorEmail == request.auth.token.email
          && request.resource.data.authorName == myName();
        allow update: if false;
        allow delete: if isAdmin();
      }
    }

    match /notifications/{notificationId} {
      allow read: if isApprovedUser() && resource.data.recipientUserId == request.auth.uid;
      allow create: if false;
      allow update: if isApprovedUser()
        && resource.data.recipientUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      allow delete: if isApprovedUser()
        && resource.data.recipientUserId == request.auth.uid
        && resource.data.isRead == true;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();

      allow create: if (isSelf(uid) && hasCorporateEmail() && isSelfRegistration())
        || isAdmin();

      allow update: if isAllowedSelfUserUpdate(uid) || isAdmin();

      allow delete: if isAdmin();
    }

    match /userCredentials/{uid} {
      allow read, write: if false;
    }

    match /audits/{auditId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
