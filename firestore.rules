rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function myRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return isAuthenticated() && myRole() == 'admin';
    }

    function isLogistics() {
      return isAuthenticated() && myRole() == 'logistica';
    }

    function isStaff() {
      return isAdmin();
    }

    function isBackoffice() {
      return isAdmin();
    }

    match /announcements/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isStaff();
    }

    match /news/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isStaff();
    }

    match /barra/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isStaff();
    }

    match /processes/{processId} {
      allow read: if isAuthenticated();
      allow create, delete: if isStaff();
      allow update: if isStaff()
        || (isLogistics()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['postReceiptNotes', 'updatedAt']));

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated()
          && request.resource.data.processId == processId
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.authorName is string;
        allow update, delete: if false;
      }
    }

    match /notificationRecipients/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if (isAuthenticated() && request.auth.uid == uid)
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipientUserId == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.actorUserId == request.auth.uid
        && request.resource.data.recipientUserId is string
        && request.resource.data.title is string
        && request.resource.data.body is string;
      allow update: if isAuthenticated()
        && resource.data.recipientUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'readAt']);
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if (isAuthenticated() && request.auth.uid == uid)
        || isStaff();

      allow create: if (isAuthenticated()
          && request.auth.uid == uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.role == 'user'
          && request.auth.token.email.matches('.*@sqquimica\\.com$'))
        || isAdmin();

      allow update: if (isAuthenticated()
          && request.auth.uid == uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.statusTone == resource.data.statusTone)
        || isAdmin();

      allow delete: if isAdmin();
    }

    match /audits/{auditId} {
      allow read: if isStaff();
      allow create: if isAdmin() || isBackoffice();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
