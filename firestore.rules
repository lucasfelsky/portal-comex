rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function myRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return isVerified() && myRole() == 'admin';
    }

    function isComexOrAdmin() {
      return isVerified() && (myRole() == 'comex' || myRole() == 'admin');
    }

    function isProcessOwner(processId) {
      return isVerified()
        && exists(/databases/$(database)/documents/processes/$(processId))
        && get(/databases/$(database)/documents/processes/$(processId)).data.createdBy == request.auth.uid;
    }

    match /announcements/{docId} {
      allow read: if isVerified();
      allow create, update, delete: if isComexOrAdmin();
    }

    match /barra/{docId} {
      allow read: if isVerified();
      allow create, update, delete: if isComexOrAdmin();
    }

    match /processes/{processId} {
      allow read: if isVerified();
      allow create: if isComexOrAdmin();
      allow update, delete: if isComexOrAdmin() || isProcessOwner(processId);
    }

    match /users/{uid} {
      allow read: if isVerified() && (request.auth.uid == uid || isAdmin() || isComexOrAdmin());

      allow create: if isAuthenticated() && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'user';

      allow update: if isVerified() && (
        (request.auth.uid == uid
          && request.resource.data.role == resource.data.role)
        || isAdmin() || isComexOrAdmin()
      );

      allow delete: if isAdmin();
    }

    match /audits/{auditId} {
      allow read: if isComexOrAdmin();
      allow create: if isComexOrAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read: if isVerified();
      allow write: if false;
    }
  }
}
