# Copie para .env e preencha com os valores do Firebase Console.
# No CI (GitHub Actions), defina estes mesmos valores como secrets/variaveis
# VITE_FIREBASE_* para que o `npm run build` bake a config no bundle.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL da UI web do IntelliQuote (link usado pelo botao da sidebar).
# Default: https://intelliquote.portal-comex.com
VITE_INTELLIQUOTE_WEB_URL=https://intelliquote.portal-comex.com