{
  "name": "sq-comex-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Portal COMEX (sq-comex-updates) - SPA React + Firebase Auth. Build vai para dist/ e deploy usa firebase.portal-comex.json para o site sq-comex-updates-3d22f no Firebase Hosting.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "echo \"no lint configured\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:vault": "node scripts/audit-vault-counts.cjs",
    "pretest": "node scripts/audit-vault-counts.cjs",
    "emulators": "firebase emulators:start --only auth,firestore,storage,functions",
    "deploy": "firebase deploy --only hosting --config firebase.portal-comex.json",
    "deploy:full": "firebase deploy --only hosting,firestore:rules,firestore:indexes,functions --config firebase.portal-comex.json",
    "deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes --config firebase.portal-comex.json",
    "deploy:intelliquote": "powershell -NoProfile -Command \"Copy-Item -Path ../Intelliquote/programa/web/dist/* -Destination ./dist-intelliquote -Recurse -Force; firebase deploy --only hosting --config firebase.intelliquote.json\""
  },
  "dependencies": {
    "firebase": "^10.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.1",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^7.2.5",
    "firebase-tools": "^13.0.0",
    "jsdom": "^25.0.0",
    "nodemailer": "^6.9.16",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  },
  "type": "module"
}
